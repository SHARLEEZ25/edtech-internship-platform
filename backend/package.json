{
  "name": "thozhil-backend",
  "version": "1.0.0",
  "description": "Backend for the Thozhil platform built with Node.js and Express. Handles core features including student onboarding, job posting, job applications, recruiter workflows, and internal dashboards. This repo contains all REST APIs, services, database models, and third party integrations for the platform.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --env-file=.env src/server.js",
    "start": "node src/server.js",
    "postinstall": "prisma db push --accept-data-loss && node prisma/seed.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SHARLEEZ25/Thozhil-Backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SHARLEEZ25/Thozhil-Backend/issues"
  },
  "homepage": "https://github.com/SHARLEEZ25/Thozhil-Backend#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.971.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@prisma/client": "5.18",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "natural": "^8.1.0",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "prisma": "5.18"
  }
}